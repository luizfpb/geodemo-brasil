{
  "name": "geodemo-brasil",
  "version": "3.0.0",
  "description": "Plataforma de análise geodemográfica dos municípios brasileiros — Censo 2022 (IBGE)",
  "author": "Luiz Felipe Brum Boy",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.{js,css}' 'tests/**/*.js'",
    "format:check": "prettier --check 'src/**/*.{js,css}' 'tests/**/*.js'",
    "test": "node --test tests/format.test.js tests/state.test.js",
    "test:e2e": "playwright test",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@turf/boolean-intersects": "^7.3.5",
    "@turf/circle": "^7.3.5",
    "chart.js": "^4.4.7",
    "leaflet": "^1.9.4",
    "simple-statistics": "^7.8.3",
    "topojson-client": "^3.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "eslint": "^8.57.0",
    "gh-pages": "^6.3.0",
    "prettier": "^3.3.0",
    "vite": "^6.3.5"
  }
}
